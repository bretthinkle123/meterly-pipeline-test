{
  "permissions": {
    "defaultMode": "auto",
    "allow": [
      "Agent",
      "Bash($HOME/.claude/hooks/*.sh)",
      "Bash($HOME/.claude/pipeline-templates/*.sh)",
      "Bash(.venv/Scripts/python.exe:*)",
      "Bash(.venv/bin/python:*)",
      "Bash(ast-grep:*)",
      "Bash(bash $HOME/.claude/pipeline-templates/*)",
      "Bash(bash ~/.claude/pipeline-templates/*)",
      "Bash(cat:*)",
      "Bash(cd:*)",
      "Bash(checkov:*)",
      "Bash(cp:*)",
      "Bash(date:*)",
      "Bash(docker info:*)",
      "Bash(docker run:*)",
      "Bash(echo:*)",
      "Bash(find:*)",
      "Bash(gh api:*)",
      "Bash(gh pr:*)",
      "Bash(gh run:*)",
      "Bash(git add:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git commit:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git ls-files:*)",
      "Bash(git push:*)",
      "Bash(git rev-parse:*)",
      "Bash(git status:*)",
      "Bash(git symbolic-ref:*)",
      "Bash(go test:*)",
      "Bash(grep:*)",
      "Bash(head:*)",
      "Bash(jq:*)",
      "Bash(ls:*)",
      "Bash(markitdown:*)",
      "Bash(mkdir:*)",
      "Bash(node:*)",
      "Bash(npm ci:*)",
      "Bash(npm install:*)",
      "Bash(npm run:*)",
      "Bash(npm test:*)",
      "Bash(osv-scanner:*)",
      "Bash(pip install:*)",
      "Bash(pytest:*)",
      "Bash(python3:*)",
      "Bash(python:*)",
      "Bash(repomix:*)",
      "Bash(semgrep:*)",
      "Bash(sha256sum:*)",
      "Bash(tail:*)",
      "Bash(terraform fmt:*)",
      "Bash(terraform plan:*)",
      "Bash(terraform validate:*)",
      "Bash(test:*)",
      "Bash(wc:*)",
      "Bash(~/.claude/hooks/*.sh)",
      "Bash(~/.claude/pipeline-templates/*.sh)",
      "Edit(./**)",
      "Glob",
      "Grep",
      "Read(./**)",
      "Read(~/.claude/**)",
      "Skill",
      "TodoWrite",
      "WebFetch(domain:anthropic.com)",
      "WebFetch(domain:code.claude.com)",
      "WebFetch(domain:developer.mozilla.org)",
      "WebFetch(domain:docs.claude.com)",
      "WebFetch(domain:docs.github.com)",
      "WebFetch(domain:docs.pydantic.dev)",
      "WebFetch(domain:docs.python.org)",
      "WebFetch(domain:fastapi.tiangolo.com)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:nodejs.org)",
      "WebFetch(domain:osv.dev)",
      "WebFetch(domain:owasp.org)",
      "WebFetch(domain:packaging.python.org)",
      "WebFetch(domain:pypi.org)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:react.dev)",
      "WebFetch(domain:registry.npmjs.org)",
      "WebFetch(domain:semgrep.dev)",
      "WebFetch(domain:www.npmjs.com)",
      "WebSearch",
      "Write(./**)",
      "mcp__aws-knowledge",
      "mcp__context7",
      "mcp__figma",
      "mcp__sentry",
      "mcp__terraform"
    ],
    "ask": [
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Write(.claude/settings.json)",
      "Edit(.claude/settings.json)",
      "Write(.claude/settings.local.json)",
      "Edit(.claude/settings.local.json)"
    ],
    "deny": [
      "Read(**/.env)",
      "Read(**/*.tfstate)",
      "Read(**/*.tfvars)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.claude/.credentials.json)",
      "Write(**/.pipeline/diff-approved)",
      "Write(**/.pipeline/plan-approved)",
      "Write(**/.pipeline/design-approved)",
      "Write(**/.pipeline/waivers.json)",
      "Edit(**/.pipeline/diff-approved)",
      "Edit(**/.pipeline/plan-approved)",
      "Edit(**/.pipeline/design-approved)",
      "Edit(**/.pipeline/waivers.json)"
    ]
  },
  "enableAllProjectMcpServers": true,
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/.claude/hooks/notify-checkpoint.sh\" attention"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "WebFetch",
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/.claude/hooks/guard-webfetch-domains.sh\""
          }
        ]
      }
    ]
  },
  "autoMode": {
    "environment": [
      "$defaults",
      "Autonomous multi-agent SDLC pipeline run. All file reads and writes must stay inside this repository (plus read-only pipeline assets under ~/.claude). Shell network access is limited to: localhost, the project's own GitHub remote (git/gh), and package-registry installs (npm/pip/go). Any other external network access must go through the WebFetch tool or a configured MCP server."
    ],
    "soft_deny": [
      "$defaults",
      "Deleting, moving, or rewriting files that live outside this repository's working directory"
    ],
    "hard_deny": [
      "$defaults",
      "Creating, modifying, or deleting the .pipeline approval markers (plan-approved, diff-approved, design-approved) or waivers.json by ANY means, including shell redirection, scripts, or git operations — these files exist solely so a human can approve pipeline checkpoints",
      "Shell commands that send data to external network destinations other than the project's git remote or package registries (use WebFetch or MCP tools instead)",
      "Using WebFetch on any domain not present in the enumerated WebFetch allow rules (mirrored in ~/.claude/hooks/webfetch-domains.txt) — unlisted domains are DENIED, never prompted; an attacker-controlled URL is an exfiltration channel",
      "Reading credential material (~/.ssh, ~/.aws, .env files, cloud or API tokens) or writing anywhere outside the repository working directory"
    ]
  }
}
